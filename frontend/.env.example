# =============================================================================
# Restaurante — variables de entorno (frontend React + Vite)
# =============================================================================
# Copia este archivo para desarrollo local:
#   cp .env.example .env.local        (Linux/macOS)
#   copy .env.example .env.local      (Windows)
#
# Vite carga .env, .env.local, .env.production, etc.
# Solo las variables con prefijo VITE_ se exponen al navegador.
#
# Guía completa: docs/INSTALACION.md
# Multi-tenant:  docs/TENANCY.md
# =============================================================================

# Dominio base para subdominios de cada restaurante (desarrollo: localhost)
VITE_TENANT_BASE_DOMAIN=localhost

# Puerto del servidor Vite en desarrollo (para enlaces entre subdominios)
VITE_TENANT_PORT=5173

# Esquema http/https para construir URLs de tenant
VITE_TENANT_SCHEME=http

# Subdominio reservado para el panel Master
VITE_TENANT_MASTER_SUBDOMAIN=master

# Subdominios reservados (no se tratan como slug de restaurante)
VITE_TENANT_RESERVED=www,api,onboarding,mail

# --- Desarrollo sin subdominio (127.0.0.1 en lugar de slug.localhost) ---
# Slug del restaurante cuando no hay subdominio en la URL.
# El API recibe el header X-Tenant-Slug con este valor.
# VITE_DEV_TENANT_SLUG=mi-restaurante

# Alternativa al anterior; mismo efecto si DEV_TENANT_SLUG no está definido.
# VITE_TENANT_DEFAULT_SLUG=mi-restaurante

# =============================================================================
# PRODUCCIÓN — ejemplo (build: npm run build)
# =============================================================================
# VITE_TENANT_BASE_DOMAIN=tudominio.com
# VITE_TENANT_SCHEME=https
# VITE_TENANT_PORT=
# (En producción el tenant se resuelve por subdominio; no uses VITE_DEV_TENANT_SLUG)
